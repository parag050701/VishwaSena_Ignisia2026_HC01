# ─────────────────────────────────────────────────────────
# HC01 Environment Configuration
# Get NVIDIA NIM keys at: https://build.nvidia.com/
# ─────────────────────────────────────────────────────────

# Primary LLM — Nemotron 3-Super 120B (clinical synthesis)
NIM_API_KEY_CHIEF=nvapi-your-chief-key-here

# Fast LLM — Llama 3 8B (ward assistant)
NIM_API_KEY_FAST=nvapi-your-fast-key-here

# Fallback LLM — Qwen 2.5 7B
NIM_API_KEY_FALLBACK=nvapi-your-fallback-key-here

# STT — NVIDIA Riva Whisper Large v3
NIM_STT_API_KEY=nvapi-your-stt-key-here
RIVA_SPEECH_BASE=grpc.nvcf.nvidia.com:443
RIVA_STT_FUNCTION_ID=b702f636-f60c-4a3d-a6f4-f3568c13bd7d

# TTS — NVIDIA Riva (optional, edge-tts used if absent)
NIM_TTS_API_KEY=nvapi-your-tts-key-here
RIVA_TTS_FUNCTION_ID=877104f7-e885-42b9-8de8-f6e4c6303969

# Local Ollama (fallback inference + embeddings)
OLLAMA_HOST=http://localhost:11434

# Data paths
HC01_DATA_DIR=.
MEDICAL_GUIDELINES_DIR=data/medical_guidelines
MEDICAL_RAG_DB_DIR=data/medical_rag_db

# LLM Council — optional HF Space second-opinion (disabled by default)
ENABLE_LLM_COUNCIL=false
LLM_COUNCIL_SPACE=burtenshaw/karpathy-llm-council
LLM_COUNCIL_TIMEOUT=180
