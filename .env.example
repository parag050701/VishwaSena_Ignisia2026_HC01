# NVIDIA NIM API Configuration
# Get keys from: https://build.nvidia.com/

# Chief Model (Nemotron 3 120B) - Advanced clinical reasoning
NIM_API_KEY_CHIEF=nvapi-your-chief-key-here

# Fallback Model (Qwen 2.5 7B) - General documentation
NIM_API_KEY_FALLBACK=nvapi-your-fallback-key-here

# Local Ollama Configuration
OLLAMA_HOST=http://localhost:11434

# Data Directory (MIMIC CSVs)
HC01_DATA_DIR=.

# Optional: Karpathy LLM Council (HF Space) second-opinion integration
ENABLE_LLM_COUNCIL=false
LLM_COUNCIL_SPACE=burtenshaw/karpathy-llm-council
LLM_COUNCIL_TIMEOUT=180

# Optional: Enable debugging
DEBUG=false
